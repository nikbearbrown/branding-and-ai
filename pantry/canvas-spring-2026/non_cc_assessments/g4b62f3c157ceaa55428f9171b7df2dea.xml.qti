            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>1163,3477,5789,9942,8619</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>ga7ae21e41801004863842f35be2839d2</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;Why is consistency important when using archetypes in branding?&lt;br&gt;&lt;i&gt;(Select all that apply.)&lt;/i&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="1163">
                <material>
                  <mattext texttype="text/plain">It reinforces trust</mattext>
                </material>
              </response_label>
              <response_label ident="3477">
                <material>
                  <mattext texttype="text/plain">It strengthens memorability</mattext>
                </material>
              </response_label>
              <response_label ident="5789">
                <material>
                  <mattext texttype="text/plain">It allows rapid reinvention</mattext>
                </material>
              </response_label>
              <response_label ident="9942">
                <material>
                  <mattext texttype="text/plain">It supports narrative coherence</mattext>
                </material>
              </response_label>
              <response_label ident="8619">
                <material>
                  <mattext texttype="text/plain">It reduces emotional resonance</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">1163</varequal>
                <varequal respident="response1">3477</varequal>
                <not>
                  <varequal respident="response1">5789</varequal>
                </not>
                <varequal respident="response1">9942</varequal>
                <not>
                  <varequal respident="response1">8619</varequal>
                </not>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>

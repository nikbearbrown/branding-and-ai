                </material>
              </response_label>
              <response_label ident="2333">
                <material>
                  <mattext texttype="text/plain">Voyage and Return (leaving &amp; coming back changed)</mattext>
                </material>
              </response_label>
              <response_label ident="4330">
                <material>
                  <mattext texttype="text/plain">Overcoming the Monster (conquering a big obstacle)</mattext>
                </material>
              </response_label>
              <response_label ident="3221">
                <material>
                  <mattext texttype="text/plain">The Hero's Journey (resilience &amp; transformation)</mattext>
                </material>
              </response_label>
              <response_label ident="2713">
                <material>
                  <mattext texttype="text/plain">Save the Cat (vulnerability &amp; relatability)</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>

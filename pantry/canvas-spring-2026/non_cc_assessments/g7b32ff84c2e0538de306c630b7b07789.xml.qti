        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p&gt;"Spotlights the people behind the organization and the people or communities it serves." This describes which type of brand story?&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="4974">
                <material>

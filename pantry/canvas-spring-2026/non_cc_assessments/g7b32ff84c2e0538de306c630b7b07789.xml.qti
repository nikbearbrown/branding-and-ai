                </material>
              </response_label>
              <response_label ident="6302">
                <material>
                  <mattext texttype="text/plain">Success Story</mattext>
                </material>
              </response_label>
              <response_label ident="7701">
                <material>
                  <mattext texttype="text/plain">People Story</mattext>
                </material>
              </response_label>
              <response_label ident="295">
                <material>
                  <mattext texttype="text/plain">Vision Story</mattext>
                </material>
              </response_label>
              <response_label ident="8820">
                <material>
                  <mattext texttype="text/plain">Value Story</mattext>
                </material>
              </response_label>
              <response_label ident="212">
                <material>
                  <mattext texttype="text/plain">Learning Story</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>

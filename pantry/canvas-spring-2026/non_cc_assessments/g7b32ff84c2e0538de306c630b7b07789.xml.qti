        </resprocessing>
      </item>
      <item ident="g2cc96595965e66486c3dde40739a626d" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>2.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>2720,4241,9058,6081,4753,9839</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>g0637575926d79a8c14b59c21ad4a4075</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p class="font-claude-response-body break-words whitespace-normal leading-[1.7]"&gt;&lt;strong&gt;Which storytelling arc does the following example represent?&lt;/strong&gt;&lt;/p&gt;
&lt;p class="font-claude-response-body break-words whitespace-normal leading-[1.7]"&gt;"I left my hometown to study abroad in Japan for a year. At first, everything felt overwhelming, the language barrier, the different academic culture, even the food. There were moments I seriously considered going home early. But over time, I found my footing, made meaningful connections, and grew in ways I never expected. When I returned home, I saw my own community with completely fresh eyes."&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="2720">
                <material>
                  <mattext texttype="text/plain">Rags to Riches (struggle to success)</mattext>
                </material>
              </response_label>
              <response_label ident="4241">
                <material>
                  <mattext texttype="text/plain">The Quest (goal-driven mission)</mattext>
                </material>
              </response_label>
              <response_label ident="9058">
                <material>
                  <mattext texttype="text/plain">Overcoming the Monster (conquering a big obstacle)</mattext>
                </material>
              </response_label>
              <response_label ident="6081">
                <material>
                  <mattext texttype="text/plain">The Hero's Journey (resilience &amp; transformation)</mattext>
                </material>
              </response_label>
              <response_label ident="4753">
                <material>
                  <mattext texttype="text/plain">Voyage and Return (leaving &amp; coming back changed)</mattext>
                </material>
              </response_label>
              <response_label ident="9839">
                <material>
                  <mattext texttype="text/plain">Save the Cat (vulnerability &amp; relatability)</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">4753</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>

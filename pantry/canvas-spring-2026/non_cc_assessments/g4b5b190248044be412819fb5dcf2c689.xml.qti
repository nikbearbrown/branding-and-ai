    <section ident="root_section">
      <item ident="g6ff7121c614c045187562337c8a312a1" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>2.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>2017,7960,6839,8164</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>g28477dfaa728997c9f121ed71d4c9984</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;According to Venkat Patla's discussion, which of the following best describes the reality of AI implementation in marketing after two years of real-world use?&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="2017">
                <material>
                  <mattext texttype="text/plain">AI has completely replaced the need for human creative directors and copywriters</mattext>
                </material>
              </response_label>
              <response_label ident="7960">
                <material>
                  <mattext texttype="text/plain">AI tools deliver 80% quality at half the cost, making them the obvious choice for all marketing content</mattext>
                </material>
              </response_label>
              <response_label ident="6839">
                <material>
                  <mattext texttype="text/plain">The industry is learning that AI effectiveness depends on understanding where human creativity still matters and where AI can enhance the process</mattext>
                </material>
              </response_label>
              <response_label ident="8164">
                <material>
                  <mattext texttype="text/plain">AI has proven to be mostly hype with little practical application in professional marketing</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">6839</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="g4557b35f27fbf835842f98486eb9bef7" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>2.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>5093,4444,1522,4328</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>g60d13d082e1004727a3444d801c680bd</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;Based on Venkat Patla's insights, what is the most critical skill for marketing professionals entering an AI-saturated industry?&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="5093">
                <material>
                  <mattext texttype="text/plain">Learning to code AI systems from scratch</mattext>
                </material>
              </response_label>
              <response_label ident="4444">
                <material>
                  <mattext texttype="text/plain">Understanding how to use AI as a tool while maintaining human creative judgment and strategic thinking</mattext>
                </material>
              </response_label>
              <response_label ident="1522">
                <material>
                  <mattext texttype="text/plain">Memorizing as many AI prompts as possible</mattext>
                </material>
              </response_label>
              <response_label ident="4328">
                <material>
                  <mattext texttype="text/plain">Avoiding AI entirely to preserve authentic creativity</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">4444</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="g7e1deb2f39971eb3449fccb8ccabf136" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>2.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>3242,6359,606,5676</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>gb31b1af5580cbb500742d20210e9a315</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;What was Venkat Patla's main advice for students entering an industry where people constantly say "AI can do this cheaper and faster"?&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="3242">
                <material>
                  <mattext texttype="text/plain">Avoid learning AI tools entirely to preserve human creativity</mattext>
                </material>
              </response_label>
              <response_label ident="6359">
                <material>
                  <mattext texttype="text/plain">Focus only on technical AI skills and abandon creative training</mattext>
                </material>
              </response_label>
              <response_label ident="606">
                <material>
                  <mattext texttype="text/plain">Understand how to articulate the value of human creative thinking, strategic judgment, and the ability to know when AI output is "good enough" versus when it lacks the essential human element</mattext>
                </material>
              </response_label>
              <response_label ident="5676">
                <material>
                  <mattext texttype="text/plain">Accept that AI will completely replace creative professionals within 2 years</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">606</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>

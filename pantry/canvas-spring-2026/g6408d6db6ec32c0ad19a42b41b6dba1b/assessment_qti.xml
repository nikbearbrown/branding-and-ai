    <section ident="root_section">
      <item ident="ge2444257bc00bd641e391fd6d6e7caf6" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.multiple_response.v0p1</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p&gt;Which of the following are reasons why personal branding resumes matter? &lt;em&gt;(Select all that apply)&lt;/em&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="8232">
                <material>
                  <mattext texttype="text/plain">They help recruiters, collaborators, and clients form strong first impressions</mattext>
                </material>
              </response_label>
              <response_label ident="7795">
                <material>
                  <mattext texttype="text/plain">They guarantee a higher salary in your next role</mattext>
                </material>
              </response_label>
              <response_label ident="6313">
                <material>
                  <mattext texttype="text/plain">They go beyond listing experience to highlight your values, personality, and qualifications</mattext>
                </material>
              </response_label>
              <response_label ident="6821">
                <material>
                  <mattext texttype="text/plain">Aligning your resume with your online presence builds trust with your audience</mattext>
                </material>
              </response_label>
              <response_label ident="1680">
                <material>
                  <mattext texttype="text/plain">They eliminate the need for any online portfolio</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">8232</varequal>
                <not>
                  <varequal respident="response1">7795</varequal>
                </not>
                <varequal respident="response1">6313</varequal>
                <varequal respident="response1">6821</varequal>
                <not>
                  <varequal respident="response1">1680</varequal>
                </not>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="gf9dd4c078812dea40c36a375fe6a16e4" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.multiple_response.v0p1</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p&gt;Which of the following are features of an ATS-friendly resume and the reasons they work? &lt;em&gt;(Select all that apply)&lt;/em&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="5784">
                <material>
                  <mattext texttype="text/plain">One-column format, because it's easy for scanners to parse left-to-right</mattext>
                </material>
              </response_label>
              <response_label ident="3617">
                <material>
                  <mattext texttype="text/plain">Decorative fonts like script or display typefaces, to stand out visually</mattext>
                </material>
              </response_label>
              <response_label ident="5208">
                <material>
                  <mattext texttype="text/plain">Simple bullet points, because they improve keyword matching</mattext>
                </material>
              </response_label>
              <response_label ident="2713">
                <material>
                  <mattext texttype="text/plain">Text-based sections, because they avoid misread text boxes</mattext>
                </material>
              </response_label>
              <response_label ident="6592">
                <material>
                  <mattext texttype="text/plain">Saving as PDF or DOCX, because it makes the file upload-safe</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">5784</varequal>
                <not>
                  <varequal respident="response1">3617</varequal>
                </not>
                <varequal respident="response1">5208</varequal>
                <varequal respident="response1">2713</varequal>
                <varequal respident="response1">6592</varequal>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="gd87dfd98d9c36c16fef8ede699fd8e37" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.multiple_choice.v0p1</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p&gt;According to Khushboo, how long do hiring managers typically spend on your online presence before deciding if you're interesting?&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="8346">
                <material>
                  <mattext texttype="text/plain">2 minutes</mattext>
                </material>
              </response_label>
              <response_label ident="8113">
                <material>
                  <mattext texttype="text/plain">1 minute</mattext>
                </material>
              </response_label>
              <response_label ident="4707">
                <material>
                  <mattext texttype="text/plain">30 seconds</mattext>
                </material>
              </response_label>
              <response_label ident="5168">
                <material>
                  <mattext texttype="text/plain">10 seconds</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">4707</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="g0cc82a866981b234c00f46b2e26c1407" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.multiple_response.v0p1</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p&gt;Which of the following are common mistakes people make with their online presence? &lt;em&gt;(Select all that apply)&lt;/em&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="4392">
                <material>
                  <mattext texttype="text/plain">Only posting finished work, instead of sharing the journey</mattext>
                </material>
              </response_label>
              <response_label ident="4527">
                <material>
                  <mattext texttype="text/plain">Being overly technical without translating content for a general audience</mattext>
                </material>
              </response_label>
              <response_label ident="7573">
                <material>
                  <mattext texttype="text/plain">Engaging with their community through two-way conversations</mattext>
                </material>
              </response_label>
              <response_label ident="5141">
                <material>
                  <mattext texttype="text/plain">Having no personality and coming across like a documentation bot</mattext>
                </material>
              </response_label>
              <response_label ident="8534">
                <material>
                  <mattext texttype="text/plain">Only talking about yourself instead of building community</mattext>
                </material>
              </response_label>
              <response_label ident="3588">
                <material>
                  <mattext texttype="text/plain">Always including screenshots, demos, and diagrams in their content</mattext>
                </material>
              </response_label>
              <response_label ident="2345">
                <material>
                  <mattext texttype="text/plain">Ignoring visuals entirely and relying only on text</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">4392</varequal>
                <varequal respident="response1">4527</varequal>
                <not>
                  <varequal respident="response1">7573</varequal>
                </not>
                <varequal respident="response1">5141</varequal>
                <varequal respident="response1">8534</varequal>
                <not>
                  <varequal respident="response1">3588</varequal>
                </not>
                <varequal respident="response1">2345</varequal>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>

    <section ident="root_section">
      <item ident="g108fc30b085162f3f523c2f1b7deb329" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_answers_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>2.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>4378,143,6202,9599,8935</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>gc93f2b65c3437d561ab0c4ea2813a1a8</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;strong&gt;Which signals indicate that UX accessibility is being treated as a strategic function rather than a last-minute fix?&lt;/strong&gt;&lt;br&gt;&lt;i&gt;(Select all that apply.)&lt;/i&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="4378">
                <material>
                  <mattext texttype="text/plain">Accessibility tied to measurable KPIs</mattext>
                </material>
              </response_label>
              <response_label ident="143">
                <material>
                  <mattext texttype="text/plain">Accessibility built into shared design systems</mattext>
                </material>
              </response_label>
              <response_label ident="6202">
                <material>
                  <mattext texttype="text/plain">Cross-functional ownership across product, design, and engineering</mattext>
                </material>
              </response_label>
              <response_label ident="9599">
                <material>
                  <mattext texttype="text/plain">Accessibility addressed only during QA</mattext>
                </material>
              </response_label>
              <response_label ident="8935">
                <material>
                  <mattext texttype="text/plain">Accessibility owned exclusively by legal/compliance teams</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">4378</varequal>
                <varequal respident="response1">143</varequal>
                <varequal respident="response1">6202</varequal>
                <not>
                  <varequal respident="response1">9599</varequal>
                </not>
                <not>
                  <varequal respident="response1">8935</varequal>
                </not>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="gaf8bbb1f560309d8bfbbaf9907f6e624" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_answers_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>2.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>4052,5225,2959,3133,731</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>gdf5d25c24ad3881398698fca2493cf11</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;strong&gt;Which choices demonstrate realistic scoping for the Madison project MVP in Week 3?&lt;/strong&gt;&lt;br&gt;&lt;i&gt;(Select all that apply.)&lt;/i&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="4052">
                <material>
                  <mattext texttype="text/plain">Defining one clear workflow</mattext>
                </material>
              </response_label>
              <response_label ident="5225">
                <material>
                  <mattext texttype="text/plain">Explicitly stating what will not be built</mattext>
                </material>
              </response_label>
              <response_label ident="2959">
                <material>
                  <mattext texttype="text/plain">Planning to use 3–5 specific n8n nodes</mattext>
                </material>
              </response_label>
              <response_label ident="3133">
                <material>
                  <mattext texttype="text/plain">Attempting to support all possible user personas</mattext>
                </material>
              </response_label>
              <response_label ident="731">
                <material>
                  <mattext texttype="text/plain">Designing a system that would require a large engineering team</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">4052</varequal>
                <varequal respident="response1">5225</varequal>
                <varequal respident="response1">2959</varequal>
                <not>
                  <varequal respident="response1">3133</varequal>
                </not>
                <not>
                  <varequal respident="response1">731</varequal>
                </not>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="g816d8dfba62146e132bd926b7eb1ee14" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_answers_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>2.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>7069,4321,3081,4591,6700</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>gbc52154c7d8b42d45cdd8ab14a172cbd</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;strong&gt;Why is the PRD treated as a “contract” in this assignment?&lt;/strong&gt;&lt;br&gt;&lt;i&gt;(Select all that apply.)&lt;/i&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="7069">
                <material>
                  <mattext texttype="text/plain">It defines scope boundaries and prevents feature creep</mattext>
                </material>
              </response_label>
              <response_label ident="4321">
                <material>
                  <mattext texttype="text/plain">It allows someone else to understand and build the solution</mattext>
                </material>
              </response_label>
              <response_label ident="3081">
                <material>
                  <mattext texttype="text/plain">It demonstrates professional product thinking</mattext>
                </material>
              </response_label>
              <response_label ident="4591">
                <material>
                  <mattext texttype="text/plain">It guarantees technical success</mattext>
                </material>
              </response_label>
              <response_label ident="6700">
                <material>
                  <mattext texttype="text/plain">It replaces the need for engineering decisions</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">7069</varequal>
                <varequal respident="response1">4321</varequal>
                <varequal respident="response1">3081</varequal>
                <not>
                  <varequal respident="response1">4591</varequal>
                </not>
                <not>
                  <varequal respident="response1">6700</varequal>
                </not>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="g90d07f78e61e815e74bb5cb7d8a5fea8" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_answers_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>2.0</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>7980,8778,5486,9933,2281</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>assessment_question_identifierref</fieldlabel>
              <fieldentry>gbe257feb830bfdc502dfc61da62bae00</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;strong&gt;What makes a strong set of success metrics in the PRD?&lt;/strong&gt;&lt;br&gt;&lt;i&gt;(Select all that apply.)&lt;/i&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="7980">
                <material>
                  <mattext texttype="text/plain">Metrics are measurable and tied to real outcomes</mattext>
                </material>
              </response_label>
              <response_label ident="8778">
                <material>
                  <mattext texttype="text/plain">There is a clear baseline and expected improvement</mattext>
                </material>
              </response_label>
              <response_label ident="5486">
                <material>
                  <mattext texttype="text/plain">Success can be evaluated after the system runs</mattext>
                </material>
              </response_label>
              <response_label ident="9933">
                <material>
                  <mattext texttype="text/plain">Metrics are aspirational but not measurable</mattext>
                </material>
              </response_label>
              <response_label ident="2281">
                <material>
                  <mattext texttype="text/plain">Success is defined as “users like it”</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">7980</varequal>
                <varequal respident="response1">8778</varequal>
                <varequal respident="response1">5486</varequal>
                <not>
                  <varequal respident="response1">9933</varequal>
                </not>
                <not>
                  <varequal respident="response1">2281</varequal>
                </not>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="gdeb3db8785e0fc8d3c91067a68e55fe9" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_answers_question</fieldentry>
            </qtimetadatafield>

            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;strong&gt;Why is active participation during guest speaker sessions emphasized in this course?&lt;/strong&gt;&lt;br&gt;&lt;i&gt;(Select all that apply.)&lt;/i&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="8114">
                <material>
                  <mattext texttype="text/plain">Career opportunities often come through relationships</mattext>
                </material>
              </response_label>
              <response_label ident="9080">
                <material>
                  <mattext texttype="text/plain">Guest speakers model real professional decision-making</mattext>
                </material>
              </response_label>
              <response_label ident="3311">
                <material>
                  <mattext texttype="text/plain">Visibility and communication are hiring signals</mattext>
                </material>
              </response_label>
              <response_label ident="3025">
                <material>
                  <mattext texttype="text/plain">Guest speakers are responsible for grading</mattext>
                </material>
              </response_label>
              <response_label ident="3345">
                <material>
                  <mattext texttype="text/plain">Attendance alone builds a professional network</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">8114</varequal>
                <varequal respident="response1">9080</varequal>
                <varequal respident="response1">3311</varequal>
                <not>
                  <varequal respident="response1">3025</varequal>
                </not>
                <not>
                  <varequal respident="response1">3345</varequal>
                </not>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>

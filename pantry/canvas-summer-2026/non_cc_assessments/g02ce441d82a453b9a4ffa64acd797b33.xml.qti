          <qtimetadatafield>
            <fieldlabel>original_answer_ids</fieldlabel>
            <fieldentry>3602,5743,2047,7831,9941</fieldentry>
          </qtimetadatafield>
        </qtimetadata>
      </itemmetadata>
      <presentation>
        <material>
          <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;&lt;strong&gt;What does flipped interaction mean? (Select all that apply)&lt;/strong&gt;&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
        </material>
        <response_lid ident="response1" rcardinality="Multiple">
          <render_choice>
            <response_label ident="3602">
              <material>
                <mattext texttype="text/plain">Users start by expressing intent, goals, or questions instead of navigating predefined menus</mattext>
              </material>
            </response_label>
            <response_label ident="5743">
              <material>
                <mattext texttype="text/plain">The system adapts its responses based on user input rather than forcing fixed workflows</mattext>
              </material>
            </response_label>
            <response_label ident="2047">
              <material>
                <mattext texttype="text/plain">The interface leads the user step-by-step with minimal user input</mattext>
              </material>
            </response_label>
            <response_label ident="7831">
              <material>
                <mattext texttype="text/plain">Interaction shifts from system-driven commands to user-driven prompts or context</mattext>
              </material>
            </response_label>
            <response_label ident="9941">
              <material>
                <mattext texttype="text/plain">The system waits for explicit instructions before showing any options or actions</mattext>
              </material>
            </response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <outcomes>
          <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
        </outcomes>
        <respcondition continue="No">
          <conditionvar>
            <and>
              <varequal respident="response1">3602</varequal>
              <varequal respident="response1">5743</varequal>
              <not>
                <varequal respident="response1">2047</varequal>
              </not>
              <varequal respident="response1">7831</varequal>
              <not>
                <varequal respident="response1">9941</varequal>
              </not>
            </and>
          </conditionvar>
          <setvar action="Set" varname="SCORE">100</setvar>
        </respcondition>
      </resprocessing>
    </item>

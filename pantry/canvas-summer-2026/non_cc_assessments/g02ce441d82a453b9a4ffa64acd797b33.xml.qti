    <item ident="g1c0d8cb299eb94cc63910a4a38a3da87" title="Question">
      <itemmetadata>
        <qtimetadata>
          <qtimetadatafield>
            <fieldlabel>question_type</fieldlabel>
            <fieldentry>multiple_choice_question</fieldentry>
          </qtimetadatafield>
          <qtimetadatafield>
            <fieldlabel>points_possible</fieldlabel>
            <fieldentry>1.0</fieldentry>
          </qtimetadatafield>
          <qtimetadatafield>
            <fieldlabel>original_answer_ids</fieldlabel>
            <fieldentry>5645,4649,3010,3605,557</fieldentry>
          </qtimetadatafield>
        </qtimetadata>
      </itemmetadata>
      <presentation>
        <material>
          <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;Professor Nik Bear Brown's Message on Academic Integrity&lt;/p&gt;
&lt;p class="p1"&gt;Professor Nik gave a speech about the foolishness of copying another student's assignment and submitting it as your own. What was his main point about why this type of cheating is "stupid" in INFO 7375?&lt;/p&gt;&lt;/div&gt;</mattext>
        </material>
        <response_lid ident="response1" rcardinality="Single">
          <render_choice>
            <response_label ident="5645">
              <material>
                <mattext texttype="text/plain">Canvas automatically flags duplicate submissions, so you'll get caught immediately and fail the course</mattext>
              </material>
            </response_label>
            <response_label ident="4649">
              <material>
                <mattext texttype="text/plain">You're paying thousands of dollars in tuition to NOT learn the exact skills employers will expect you to have</mattext>
              </material>
            </response_label>
            <response_label ident="3010">
              <material>
                <mattext texttype="text/plain">The student you copied from will likely report you to avoid getting in trouble themselves</mattext>
              </material>
            </response_label>
            <response_label ident="3605">
              <material>
                <mattext texttype="text/plain">Graduate programs share academic integrity violations, which will follow you throughout your career</mattext>
              </material>
            </response_label>
            <response_label ident="557">
              <material>
                <mattext texttype="text/plain">In a class about AI and branding, you're learning to use tools that will do the work FOR you legally. So why cheat?</mattext>
              </material>
            </response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <outcomes>
          <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
        </outcomes>
        <respcondition continue="No">
          <conditionvar>
            <varequal respident="response1">4649</varequal>
          </conditionvar>
          <setvar action="Set" varname="SCORE">100</setvar>
        </respcondition>
      </resprocessing>
    </item>
    <item ident="g03005e8b228814301eac261b34a16c45" title="Question">
      <itemmetadata>
        <qtimetadata>
          <qtimetadatafield>
            <fieldlabel>question_type</fieldlabel>
            <fieldentry>multiple_choice_question</fieldentry>
          </qtimetadatafield>
          <qtimetadatafield>
            <fieldlabel>points_possible</fieldlabel>
            <fieldentry>1.0</fieldentry>
          </qtimetadatafield>
          <qtimetadatafield>
            <fieldlabel>original_answer_ids</fieldlabel>
            <fieldentry>8435,2783,8904,3370,536</fieldentry>
          </qtimetadatafield>
        </qtimetadata>
      </itemmetadata>
      <presentation>
        <material>
          <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;&lt;strong&gt;Guy Kawasaki's Famous 10/20/30 Rule for Presentations&lt;/strong&gt;&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p class="p1"&gt;&lt;strong&gt;According to Guy Kawasaki's presentation philosophy explained in class, what does the "30" in the 10/20/30 rule refer to?&lt;/strong&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
        </material>
        <response_lid ident="response1" rcardinality="Single">
          <render_choice>
            <response_label ident="8435">
              <material>
                <mattext texttype="text/plain">Present to no more than 30 people at a time for maximum engagement</mattext>
              </material>
            </response_label>
            <response_label ident="2783">
              <material>
                <mattext texttype="text/plain">Use a minimum 30-point font size so you must know your material</mattext>
              </material>
            </response_label>
            <response_label ident="8904">
              <material>
                <mattext texttype="text/plain">Spend no more than 30 seconds per slide to maintain pace</mattext>
              </material>
            </response_label>
            <response_label ident="3370">
              <material>
                <mattext texttype="text/plain">Include no more than 30 words per slide to avoid clutter</mattext>
              </material>
            </response_label>
            <response_label ident="536">
              <material>
                <mattext texttype="text/plain">Practice your presentation at least 30 times before delivering it</mattext>
              </material>
            </response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <outcomes>
          <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
        </outcomes>
        <respcondition continue="No">
          <conditionvar>
            <varequal respident="response1">2783</varequal>
          </conditionvar>
          <setvar action="Set" varname="SCORE">100</setvar>
        </respcondition>
      </resprocessing>
    </item>
    <item ident="g96282febf0d41222ba5c31fed3a965ac" title="Question">
      <itemmetadata>
        <qtimetadata>
          <qtimetadatafield>
            <fieldlabel>question_type</fieldlabel>
            <fieldentry>multiple_choice_question</fieldentry>
          </qtimetadatafield>
          <qtimetadatafield>
            <fieldlabel>points_possible</fieldlabel>
            <fieldentry>2.0</fieldentry>
          </qtimetadatafield>
          <qtimetadatafield>
            <fieldlabel>original_answer_ids</fieldlabel>
            <fieldentry>566,3093,5475,9804,3667</fieldentry>
          </qtimetadatafield>
        </qtimetadata>
      </itemmetadata>
      <presentation>
        <material>
          <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;You have been given 8 minutes to present your Madison Framework midterm project. Based on class guidelines and Guy Kawasaki's presentation principles, what is the best approach to managing this time?&lt;/p&gt;&lt;/div&gt;</mattext>
        </material>
        <response_lid ident="response1" rcardinality="Single">
          <render_choice>
            <response_label ident="566">
              <material>
                <mattext texttype="text/plain">Use all 8 minutes for your presentation and answer questions after class if needed</mattext>
              </material>
            </response_label>
            <response_label ident="3093">
              <material>
                <mattext texttype="text/plain">Present for 6-7 minutes and leave 1-2 minutes for Q&amp;A to stay within the time limit</mattext>
              </material>
            </response_label>
            <response_label ident="5475">
              <material>

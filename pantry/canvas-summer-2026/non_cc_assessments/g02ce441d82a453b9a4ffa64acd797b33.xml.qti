    <item ident="gc93f2b65c3437d561ab0c4ea2813a1a8" title="Question">
      <itemmetadata>
        <qtimetadata>
          <qtimetadatafield>
            <fieldlabel>question_type</fieldlabel>
            <fieldentry>multiple_answers_question</fieldentry>
          </qtimetadatafield>
          <qtimetadatafield>
            <fieldlabel>points_possible</fieldlabel>
            <fieldentry>1.0</fieldentry>
          </qtimetadatafield>
          <qtimetadatafield>
            <fieldlabel>original_answer_ids</fieldlabel>
            <fieldentry>4378,143,6202,9599,8935</fieldentry>
          </qtimetadatafield>
        </qtimetadata>
      </itemmetadata>
      <presentation>
        <material>
          <mattext texttype="text/html">&lt;div&gt;&lt;strong&gt;Which signals indicate that UX accessibility is being treated as a strategic function rather than a last-minute fix?&lt;/strong&gt;&lt;br&gt;&lt;i&gt;(Select all that apply.)&lt;/i&gt;&lt;/div&gt;</mattext>
        </material>
        <response_lid ident="response1" rcardinality="Multiple">
          <render_choice>
            <response_label ident="4378">
              <material>
                <mattext texttype="text/plain">Accessibility tied to measurable KPIs</mattext>
              </material>
            </response_label>
            <response_label ident="143">
              <material>
                <mattext texttype="text/plain">Accessibility built into shared design systems</mattext>
              </material>
            </response_label>
            <response_label ident="6202">
              <material>
                <mattext texttype="text/plain">Cross-functional ownership across product, design, and engineering</mattext>
              </material>
            </response_label>
            <response_label ident="9599">
              <material>
                <mattext texttype="text/plain">Accessibility addressed only during QA</mattext>
              </material>
            </response_label>
            <response_label ident="8935">
              <material>
                <mattext texttype="text/plain">Accessibility owned exclusively by legal/compliance teams</mattext>
              </material>
            </response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <outcomes>
          <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
        </outcomes>
        <respcondition continue="No">
          <conditionvar>
            <and>
              <varequal respident="response1">4378</varequal>
              <varequal respident="response1">143</varequal>
              <varequal respident="response1">6202</varequal>
              <not>
                <varequal respident="response1">9599</varequal>
              </not>
              <not>
                <varequal respident="response1">8935</varequal>
              </not>
            </and>
          </conditionvar>
          <setvar action="Set" varname="SCORE">100</setvar>
        </respcondition>
      </resprocessing>
    </item>
    <item ident="gdf5d25c24ad3881398698fca2493cf11" title="Question">

        <respcondition continue="No">
          <conditionvar>
            <and>
              <varequal respident="response1">7069</varequal>
              <varequal respident="response1">4321</varequal>
              <varequal respident="response1">3081</varequal>
              <not>
                <varequal respident="response1">4591</varequal>
              </not>
              <not>
                <varequal respident="response1">6700</varequal>
              </not>
            </and>
          </conditionvar>
          <setvar action="Set" varname="SCORE">100</setvar>
        </respcondition>
      </resprocessing>
    </item>

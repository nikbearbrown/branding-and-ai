      </itemmetadata>
      <presentation>
        <material>
          <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;What does Dhruv Patel mean by saying we are entering the "Verification Age" rather than the "Information Age"?&lt;strong&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
        </material>
        <response_lid ident="response1" rcardinality="Single">

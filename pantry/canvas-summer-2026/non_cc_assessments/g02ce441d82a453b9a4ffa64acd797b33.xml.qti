              </material>
            </response_label>
            <response_label ident="4321">
              <material>
                <mattext texttype="text/plain">It allows someone else to understand and build the solution</mattext>
              </material>
            </response_label>
            <response_label ident="3081">
              <material>
                <mattext texttype="text/plain">It demonstrates professional product thinking</mattext>
              </material>
            </response_label>
            <response_label ident="4591">
              <material>
                <mattext texttype="text/plain">It guarantees technical success</mattext>
              </material>
            </response_label>
            <response_label ident="6700">
              <material>
                <mattext texttype="text/plain">It replaces the need for engineering decisions</mattext>
              </material>
            </response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <outcomes>
          <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>

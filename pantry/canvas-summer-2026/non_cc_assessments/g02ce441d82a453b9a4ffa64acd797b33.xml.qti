              <varequal respident="response1">4052</varequal>
              <varequal respident="response1">5225</varequal>
              <varequal respident="response1">2959</varequal>
              <not>
                <varequal respident="response1">3133</varequal>
              </not>
              <not>
                <varequal respident="response1">731</varequal>
              </not>
            </and>
          </conditionvar>
          <setvar action="Set" varname="SCORE">100</setvar>
        </respcondition>
      </resprocessing>

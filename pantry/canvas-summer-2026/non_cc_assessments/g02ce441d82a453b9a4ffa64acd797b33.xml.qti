          </qtimetadatafield>
        </qtimetadata>
      </itemmetadata>
      <presentation>
        <material>
          <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;According to the presentation, which traits are associated with &lt;span class="s1"&gt;&lt;strong&gt;indispensable brands&lt;/strong&gt;&lt;/span&gt;?&lt;/p&gt;
&lt;p class="p1"&gt;&lt;i&gt;(Select all that apply)&lt;/i&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
        </material>
        <response_lid ident="response1" rcardinality="Multiple">
          <render_choice>
            <response_label ident="2736">
              <material>
                <mattext texttype="text/plain">Customers request the brand by name</mattext>
              </material>
            </response_label>
            <response_label ident="7204">
              <material>
                <mattext texttype="text/plain">Selected mainly because they are the cheapest option</mattext>
              </material>
            </response_label>
            <response_label ident="4922">
              <material>
                <mattext texttype="text/plain">Built on emotional connection, not just features</mattext>
              </material>
            </response_label>
            <response_label ident="926">
              <material>
                <mattext texttype="text/plain">Easily replaced when an AI agent suggests alternatives</mattext>
              </material>
            </response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <outcomes>
          <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
        </outcomes>
        <respcondition continue="No">
          <conditionvar>
            <and>
              <varequal respident="response1">2736</varequal>
              <not>
                <varequal respident="response1">7204</varequal>
              </not>
              <varequal respident="response1">4922</varequal>
              <not>
                <varequal respident="response1">926</varequal>
              </not>
            </and>
          </conditionvar>
          <setvar action="Set" varname="SCORE">100</setvar>
        </respcondition>
      </resprocessing>
    </item>
    <item ident="g6214cf712294052d291163215bba6977" title="Question">

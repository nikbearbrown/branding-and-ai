      <item ident="g53a3a9fa533616b60df8d3b58c390843" title="Question">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>cc_profile</fieldlabel>
              <fieldentry>cc.multiple_response.v0p1</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;&lt;p class="p1"&gt;Which reasons explain why archetypes are effective tools in branding and personal branding?&amp;nbsp;&lt;/p&gt;
&lt;p class="p1"&gt;&lt;i&gt;(Select all that apply.)&lt;/i&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Multiple">
            <render_choice>
              <response_label ident="9166">
                <material>
                  <mattext texttype="text/plain">They tap into shared psychological patterns</mattext>
                </material>
              </response_label>
              <response_label ident="8178">
                <material>
                  <mattext texttype="text/plain">They make brands easier to emotionally recognize</mattext>
                </material>
              </response_label>
              <response_label ident="3869">
                <material>
                  <mattext texttype="text/plain">They replace the need for consistent messaging</mattext>
                </material>
              </response_label>
              <response_label ident="8367">
                <material>
                  <mattext texttype="text/plain">They help audiences quickly infer values</mattext>
                </material>
              </response_label>
              <response_label ident="8130">
                <material>
                  <mattext texttype="text/plain">They work only when consumers consciously analyze them</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <and>
                <varequal respident="response1">9166</varequal>
                <varequal respident="response1">8178</varequal>
                <not>
                  <varequal respident="response1">3869</varequal>
                </not>
                <varequal respident="response1">8367</varequal>
                <not>
                  <varequal respident="response1">8130</varequal>
                </not>
              </and>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>

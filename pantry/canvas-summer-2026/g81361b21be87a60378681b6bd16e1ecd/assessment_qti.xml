&lt;p class="p1"&gt;In your response, reference &lt;strong&gt;at least one concept&lt;/strong&gt; from the presentation (e.g., indispensable vs. disposable, doing one thing exceptionally well, emotional connection, ecosystems, or being requested by name).&lt;/p&gt;
&lt;p class="p1"&gt;&lt;i&gt;(3–5 sentences)&lt;/i&gt;&lt;/p&gt;&lt;/div&gt;</mattext>
          </material>
          <response_str ident="response1" rcardinality="Single">
            <render_fib>
              <response_label ident="answer1" rshuffle="No"/>
            </render_fib>
          </response_str>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <other/>
            </conditionvar>
          </respcondition>
        </resprocessing>
      </item>
